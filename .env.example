# StoaBoard — ortam değişkenleri örneği
# Bu dosyayı .env olarak kopyalayıp doldurun: cp .env.example .env

# Güçlü ve rastgele bir değer kullanın (örn: python -c "import secrets; print(secrets.token_hex(32))")
# Boş bırakılırsa uygulama otomatik olarak .secret_key dosyasına bir anahtar üretir.
# SECRET_KEY=buraya-guclu-bir-anahtar-yazin

# Üretim ortamında HTTPS zorunlu kılar
# SESSION_COOKIE_SECURE=true

# WebSocket için izin verilen origin (virgülle ayırın)
# CORS_ORIGINS=https://yourdomain.com

# Farklı bir veritabanı kullanmak için (varsayılan: SQLite)
# DATABASE_URL=sqlite:///stoaboard.db
